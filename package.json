{
  "name": "@gnolang/tm2-rpc",
  "version": "0.0.1",
  "description": "Tendermint2 RPC clients",
  "license": "Apache-2.0",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "files": [
    "build/",
    "*.md",
    "!*.spec.*",
    "!**/testdata/"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "build": "rm -rf ./build && tsc",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@cosmjs/crypto": "^0.34.0",
    "@cosmjs/encoding": "^0.34.0",
    "@cosmjs/json-rpc": "^0.34.0",
    "@cosmjs/math": "^0.34.0",
    "@cosmjs/socket": "^0.34.0",
    "@cosmjs/stream": "^0.34.0",
    "@cosmjs/utils": "^0.34.0",
    "cross-fetch": "^4.1.0",
    "readonly-date": "^1.0.0",
    "xstream": "^11.14.0"
  },
  "devDependencies": {
    "@bufbuild/protobuf": "^2.7.0",
    "@eslint/js": "^9.30.1",
    "@stylistic/eslint-plugin": "^5.1.0",
    "@types/node": "^20.14.8",
    "@vitest/coverage-istanbul": "^3.2.4",
    "eslint": "^9.30.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "glob": "^11",
    "ses": "^1.13.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.36.0",
    "vitest": "^3.2.4"
  }
}
