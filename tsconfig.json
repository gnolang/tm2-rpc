{
    "compilerOptions": {
      "rootDir": "src",
      "outDir": "build",
      "strict": true,
      "target": "ES2020",
      "module": "commonjs",
      "sourceMap": true,
      "esModuleInterop": true,
      "resolveJsonModule": true,
      "moduleResolution": "node",
      "allowArbitraryExtensions": true,
      "skipLibCheck": true,      
    },
    "include": [
      "src/**/*.ts",
      "src/**/*.json"
    ],
  }